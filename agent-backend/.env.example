# Application
PORT=8000
DEBUG=true

# LLM Models
OPENAI_API_KEY=""
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Anthropic (optional)
ANTHROPIC_API_KEY=""

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT=universal-agent

# MCP Servers (JSON array)
MCP_SERVERS='[
  {
    "name": "filesystem",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem", "/your-filesystem-local-path"]
  },
  {
    "name": "remote-mcp-tools",
    "url": "http://your-mcp-server-host:port/mcp",
    "transport": "streamable_http"
  },
  {
    "name": "feishu",
    "url": "http://localhost:3333/sse?userKey=universal_agent_backend",
    "transport": "sse"
  }
]'
